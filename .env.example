# ── Calendar Credentials ─────────────────────────────
# You can configure these here OR use the GUI at /admin → Accounts tab.
# The GUI stores credentials in an encrypted file (data/credentials.enc)
# which takes priority over these .env values.

# Google Calendar OAuth2 (optional if using GUI setup)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REFRESH_TOKEN=your-refresh-token
GOOGLE_CALENDAR_IDS=primary,family123@group.calendar.google.com

# iCloud CalDAV (optional if using GUI setup)
ICLOUD_USERNAME=your-apple-id@icloud.com
ICLOUD_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
ICLOUD_CALENDAR_NAMES=Family,Trevor,Larissa

# ── Apple Reminders Webhook ──────────────────────────
REMINDERS_WEBHOOK_SECRET=change-me-to-a-random-string

# ── Server ───────────────────────────────────────────
PORT=3000
SYNC_INTERVAL_MINUTES=5
DISPLAY_TIMEZONE=America/New_York

# ── Calendar Window ──────────────────────────────────
CALENDAR_DAYS_BACK=7
CALENDAR_DAYS_FORWARD=14

# ── Network Security (optional) ──────────────────────
# Bind to a specific interface (default: 0.0.0.0 = all interfaces)
# Set to 127.0.0.1 to only allow connections from this machine
# HOST=0.0.0.0

# Restrict access to specific IP ranges (CIDR notation, comma-separated)
# Only clients from these networks can reach the server.
# Example: your LAN subnet + localhost
# ALLOWED_NETWORKS=10.0.0.0/24,127.0.0.1

# ── Admin Security (optional) ────────────────────────
# Set a numeric PIN to protect the /admin panel
# ADMIN_PIN=1234

# Auto-generated encryption key for credential store (do not edit)
# CREDENTIAL_SECRET=<auto-generated on first run>
